# Siscar Backend — Variáveis de Ambiente

# JWT Secret — TROQUE por uma string aleatória longa em produção!
JWT_SECRET=siscar_super_secret_jwt_key_2024_change_in_production

# JWT Expiration (8h padrão)
JWT_EXPIRES_IN=8h

# Porta do servidor
PORT=3001

# Ambiente (development / production)
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Em produção, coloque o domínio real:
# FRONTEND_URL=https://app.siscar.com.br
